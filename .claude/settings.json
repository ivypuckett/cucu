{
  "allowedTools": [
    "Bash(task *)",
    "Bash(bundle *)",
    "Bash(npm *)",
    "Bash(cmake *)",
    "Bash(nim *)",
    "Bash(mkdir *)",
    "Bash(git add*)",
    "Bash(git commit*)",
    "Bash(git push*)",
    "Bash(git status*)",
    "Bash(git log*)",
    "Bash(git diff*)",
    "Bash(git fetch*)",
    "Bash(git pull*)",
    "Bash(git branch*)",
    "Bash(git checkout*)",
    "Bash(git stash*)"
  ],
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/session-start.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/pre-commit.sh"
          }
        ]
      }
    ]
  }
}
